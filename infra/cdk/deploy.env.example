# Copy this file to deploy.env and fill in values.
# Do not commit deploy.env (it may contain credentials).

# Required
AWS_ACCOUNT_ID=123456789012
# Use AWS region code here (not Availability Zone code).
# For Manila Local Zone (ap-southeast-1-mnl-1a), region is still ap-southeast-1.
AWS_REGION=ap-southeast-1

# Authentication mode (choose one)
# 1) Recommended: use a named AWS profile from ~/.aws/credentials
AWS_PROFILE=default
#
# 2) Or use direct keys (leave AWS_PROFILE empty if you use this)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Stack context (optional)
PROJECT_NAME=bebe-ims
ENVIRONMENT_NAME=prod
API_PREFIX=/api/v1
TABLE_NAME=bebe_ims
BACKEND_CPU=512
BACKEND_MEMORY_MIB=1024
BACKEND_DESIRED_COUNT=1

# Frontend build config
FRONTEND_API_BASE=/api/v1

# Deployment behavior
AUTO_BOOTSTRAP=true
RUN_MIGRATE=true
