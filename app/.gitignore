# Based on:
# - https://github.com/github/gitignore/blob/main/Node.gitignore
# - https://github.com/github/gitignore/blob/main/Global/macOS.gitignore

# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build output
build/
dist/
.cache/
.parcel-cache/

# Test output
coverage/
/flow-*

# Framework/tool output
.next/
.nuxt/
.svelte-kit/
*.tsbuildinfo

# Development/editor
.vscode/
.idea/
*.iml
*.swp

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
env_file

# Generated/project-specific
__generated__/
data/*
.scannerwork/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# macOS
.DS_Store

!.gitkeep
