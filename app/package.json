{
  "name": "bloom-portal",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "test:coverage": "react-scripts test --env=jsdom --coverage",
    "lint": "./scripts/lint.sh",
    "lint:fix": "eslint src --fix && stylelint \"src/**/*.js, **/*.css, !**/docker/**\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json,md}\"",
    "stylelint": "stylelint \"src/**/*.js, **/*.css, !**/docker/**\"",
    "lint:watch": "node_modules/.bin/esw webpack.config.* src test config --watch",
    "nvm": "curl -s -o- https://raw.githubusercontent.com/creationix/nvm/v0.33.2/install.sh | bash && . ~/.nvm/nvm.sh && nvm install <./.nvmrc && nvm use <./.nvmrc",
    "remove-test-bundles": "./scripts/remove-test-bundles.js",
    "generate": "plop --plopfile ./generators/index.js"
  },
  "dependencies": {
    "assertion-error": "^1.1.0",
    "bignumber.js": "^9.0.0",
    "date-fns": "^1.28.5",
    "debounce": "^1.1.0",
    "enzyme": "^3.9.0",
    "enzyme-adapter-react-16": "^1.11.2",
    "enzyme-wait": "^1.0.9",
    "eslint-config-airbnb": "^16.1.0",
    "eslint-import-resolver-webpack": "^0.10.0",
    "eslint-plugin-lodash": "^2.7.0",
    "faker": "^5.5.3",
    "final-form": "^4.8.3",
    "final-form-arrays": "^1.0.4",
    "final-form-focus": "^1.1.2",
    "fuse.js": "^3.4.4",
    "history": "^4.7.2",
    "lodash": "^4.17.19",
    "mock-dom-storage": "^1.0.0",
    "moment-range": "^4.0.2",
    "moment-timezone": "^0.5.31",
    "node-fetch": "^2.6.1",
    "postcss": "^6.0.22",
    "postcss-syntax": "^0.10.0",
    "prop-types": "^15.6.1",
    "qrcode.react": "^1.0.0",
    "qs": "^6.6.0",
    "rc-progress": "^2.2.5",
    "react": "^16.8.4",
    "react-datepicker": "^2.14.0",
    "react-dom": "^16.8.4",
    "react-final-form": "^6.3.0",
    "react-final-form-arrays": "^1.0.6",
    "react-ga": "^3.3.0",
    "react-hotjar": "^2.2.1",
    "react-modal": "^3.3.2",
    "react-notification-system": "^0.4.0",
    "react-number-format": "^4.0.7",
    "react-redux": "^7.1.3",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "react-scripts": "2.1.8",
    "react-select": "^3.1.1",
    "react-styled-flexboxgrid": "^2.2.0",
    "react-table": "^6.8.0",
    "react-test-renderer": "^16.8.4",
    "react-tippy": "^1.2.3",
    "react-web-vitals": "^1.0.1",
    "recharts": "^2.0.9",
    "recompose": "0.26.0",
    "redux": "^4.0.0",
    "redux-api-middleware": "^3.0.1",
    "redux-observable": "^1.2.0",
    "reselect": "^4.0.0",
    "rxjs": "^6.5.3",
    "styled-components": "^4.0.0",
    "stylelint": "^9.2.1",
    "stylelint-config-recommended": "^2.1.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-processor-styled-components": "^1.3.1",
    "timezones.json": "^1.3.3",
    "typeface-roboto": "^0.0.35",
    "typeface-roboto-condensed": "^0.0.54",
    "us": "^2.0.0",
    "uuid": "^8.3.0"
  },
  "devDependencies": {
    "plop": "^2.5.3",
    "prettier": "^3.6.2"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
