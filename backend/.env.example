BEBE_IMS_APP_ENV=development
BEBE_IMS_API_PREFIX=/api/v1
BEBE_IMS_AWS_REGION=ap-southeast-1
BEBE_IMS_DYNAMODB_TABLE_NAME=bebe_ims
# Optional override. If omitted, backend loads endpoint from config/dynamodb.local.json
# BEBE_IMS_DYNAMODB_ENDPOINT_URL=http://localhost:8000
BEBE_IMS_DYNAMODB_LOCAL_CONFIG_FILE=config/dynamodb.local.json
BEBE_IMS_CORS_ORIGINS=http://localhost:2306,http://127.0.0.1:2306,http://localhost:3000,http://127.0.0.1:3000,http://192.168.0.50:2306
BEBE_IMS_CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|192\\.168\\.\\d{1,3}\\.\\d{1,3}|10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[0-1])\\.\\d{1,3}\\.\\d{1,3})(:\\d+)?$
BEBE_IMS_SLICER_CLI_PATH=
BEBE_IMS_SLICER_PROFILES_ROOT=/Applications/BambuStudio.app/Contents/Resources/profiles/BBL
BEBE_IMS_SLICER_MACHINE_PRESET=Bambu Lab A1 0.4 nozzle.json
BEBE_IMS_SLICER_PROCESS_PRESET=0.20mm Standard @BBL A1.json
BEBE_IMS_SLICER_LOAD_DEFAULT_FILAMENT=true
BEBE_IMS_SLICER_ALLOW_NEWER_FILE=true
